# Backend Configuration
PORT=5000
NODE_ENV=development

# Database (Optional - uses in-memory storage if not provided)
MONGO_URI=mongodb://localhost:27017/ai-resume-analyzer

# Authentication
# IMPORTANT: Generate a strong random key. Never commit the actual key to git.
JWT_SECRET=change_this_to_a_strong_random_key_in_production

# AI API
# IMPORTANT: Never commit your actual API key. Use Vercel Environment Variables instead.
# Copy your Gemini API key from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL (for CORS in production)
REACT_APP_API_URL=http://localhost:5000
