{
  "name": "ai-resume-analyzer",
  "version": "1.0.0",
  "description": "AI-powered resume analyzer using Gemini API",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:client\"",
    "dev:backend": "cd server/backend && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "npm run build:client && npm run build:backend",
    "build:client": "cd client && npm run build",
    "build:backend": "cd server/backend && npm install",
    "build:all": "npm run build:client && npm run build:backend",
    "start": "node server/backend/server.js",
    "install:all": "npm install && cd server/backend && npm install && cd ../../client && npm install"
  },
  "keywords": [
    "resume",
    "analyzer",
    "gemini",
    "ai"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mongoose": "^9.2.4",
    "vite": "^7.3.1"
  }
}
